{
  "name": "logcat-pro",
  "version": "1.0.0",
  "description": "LogCat Pro",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder --win --dir",
    "dist": "electron-vite build && electron-builder --win",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@tanstack/vue-virtual": "^3.10.0",
    "@types/pdfkit": "^0.17.5",
    "@vueuse/core": "^11.0.0",
    "better-sqlite3": "^11.0.0",
    "echarts": "^5.5.0",
    "element-plus": "^2.8.0",
    "marked": "^17.0.4",
    "pdfkit": "^0.18.0",
    "pinia": "^2.2.0",
    "sql.js": "^1.14.1",
    "vue": "^3.5.0",
    "vue-echarts": "^7.0.0",
    "vue-json-pretty": "^2.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/marked": "^5.0.2",
    "@vitejs/plugin-vue": "^5.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0"
  },
  "build": {
    "appId": "com.logcat.pro",
    "productName": "LogCat Pro",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "LogCat Pro"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
